.Sh "OAUTH INTEGRATION"
OAuth authorization methods are available,
but integration does currently not exist.
However, an external Python3 tool,
.Va build-oauth-helper ,
can be driven to use OAuth, via the support macros shown next.
The macros
.Dq play some games
with scopes of
.Sx VARIABLES ,
it is therefore best to use these from within an
.Ic account
scope.
.Ss "OAuth: personal code"
An example how to use the OAuth support macros below.
.Bd -literal -offset indent
account my-acc {
	\ecall my-acc
}
define my-acc {
	# do account stuff ..., then
	\excall my-oauth-activate my-acc
}

define my-oauth-activate { # [$1=account-name]
	\elocal se a=$1
	\eif -z $a; \ese a=$account; \een

	# (Examples..)
	\ese password \e
		imap-auth=xoauth2 pop3-auth=xoauth2 \e
		smtp-config=-allmechs,xoauth2 \e

	# How to drive machine: unfortunately it, before v15,
	# is not called when credentials are needed, but must
	# "keep credentials hot"
	\ese on-main-loop-tick=oauth-check-token \e
		on-compose-enter=oauth-check-token

	# Set generic code callback(s), and initialize machine
	\ecall oauth-check-token-init
	\ese oauth-helper="$build-oauth-helper -R ~/.$a.oauth" \e
		oauth-helper-times=~/.$a.oauth \e
		on-oauth-password-change=.my-oauth-on-new-token
}

define .my-oauth-on-new-token { # [$1=password, or empty]
	\eif -n $1
		\eechoe ' .. updating password to OAuth token '"$1"
		\ese password=$1
		\eif $mailbox-resolved =~ ^imaps?://
			\eechoe '.. password change, reconnect IMAP'
			\edisco
			\econn
		\een
	\eel
		\eechoe ' .. deleting password'
		\euns password
	\een
}
.Ed
.Ss "OAuth: support macros"
Support macros which
.Bl -bullet -compact
.It
Call the
.Va oauth-helper
script, and expect a password to appear on its standard output.
.Va build-oauth-helper ,
if available, complies.
.It
Invoke the
.Va on-oauth-password-change
macro if that condition triggers.
.It
Can avoid invoking the helper too often if
.Va oauth-helper-times
is set, and points to an .INI-style configuration file that has
.Ql timestamp=
and
.Ql timeout=
directives, interpreted as UNIX time epoch seconds.
.Va build-oauth-helper ,
if available, complies.
.El
.Bd -literal -offset indent
# Initialize needed variables "in scope",
# so they disappear again when that is left:
# to be called first
define oauth-check-token-init {
	\ese oauth-helper oauth-helper-times \e
		on-oauth-password-change \e
		_oauth-pass _oauth-timeout
}

# Workhorse, to be called periodically
# TODO v15: will be called from within, when needed
define oauth-check-token {
	\eif -Z oauth-helper; \eretu; \een

	\eif -n $_oauth-timeout
		\elocal >sec vexpr seconds
		\eif $((sec + 60*21)) -lt $_oauth-timeout
			\eretu
		\een
		\euns _oauth-timeout
	\een

	\eeval local >i ! $oauth-helper # eval to resolve $VARs
	\elocal se j=$? d=$?/$!/$^ERRDOC
	\eif $j -ne 0
		\eechoe '! $oauth-helper failed, unset: '\e
			"$d: $oauth-helper"
		\euns oauth-helper
		\ecall_if "$on-oauth-password-change"
		\eretu
	\een

	\e>i csop trim "$i"
	\eif $_oauth-pass != $i
		\ese _oauth-pass=$i
		\eif -N verbose
			\eechoe 'New Oauth 2.0 access token'
		\een
		\eif -N on-oauth-password-change
			\ecall_if "$on-oauth-password-change" \e
				"$_oauth-pass"
		\eel
			\eechoe '! No $on-oauth-password-change \e
				to update"
		\een
	\een

	\eif -n $oauth-helper-times
		\excall .oauth-helper-times
	\een
}

define .oauth-helper-times {
	# eval to resolve $VARs
	\eeval readctl create "$oauth-helper-times"
	\elocal se j=$? d=$^ERRDOC
	\eif $j -ne 0
		\eechoe '! $oauth-helper-times inaccessible, \e
			unset: '"$d: $oauth-helper-times"
		\euns oauth-helper-times
		\eretu
	\een
	\elocal readall _oauth_args
	\eeval readctl remove "$oauth-helper-times"

	\elocal se ifs=$'\en'; \evpospar evalset "$_oauth_args"; \e
		\euns ifs
	\eour call .oauth-check-token-recur "$@"

	\eif -N _oauth_ts && -N _oauth_to
		: $((_oauth-timeout = _oauth_ts + _oauth_to))
		\eif -N verbose
			\elocal >sec vexpr seconds
			\eechoe 'I OAuth password timeout at epoch '\e
				"$_oauth-timeout, now $sec, to-go \e
				$((_oauth-timeout - sec))"
		\een
	\eel
		\eechoe '! $oauth-helper-times content bogus, \e
			unset: '"$oauth-helper-times"
		\euns oauth-helper-times
	\een
}

define .oauth-check-token-recur {
	\eif $# -eq 0; \eretu; \een
	\eif $1 =~ ^[[:space:]]*time(stamp|out)[[:space:]]*=\e
			[[:space:]]*([[:digit:]]+).*
		\eif $^1 == stamp
			\ese _oauth_ts=$^2
		el
			\ese _oauth_to=$^2
		\een
	\een
	\eshift
	\excall .oauth-check-token-recur "$@"
}
.Ed
.Sh SIGNATURES
Appending signatures can be achieved in multiple ways.
The possibly easiest approach uses the
.Va \&\&on-compose-embed
hook to include some persistent file:
again, multiple ways are possible.
.Bd -literal -offset indent
set on-compose-embed=.sig.embed
define .sig.embed {
	~< ~/.mysig
}

# ..or..

\edef .sig.embed {
Yes, part of message body!
	Ciao!
	~:se sign=$'\een--Silver'
	~a
	~:call ..sig.embed
}
\edef ..sig.embed {
	echo normal macro, it has no body access!

	digmsg - h l
	ec "1:$^0: $^*"

	# via I/O protocol
	digmsg create -
	digmsg - h l
	local readall x
	ec "2:$x"
	digmsg remove -

	# but easier, via built-in "in-memory" protocol
	digmsg - h l
	ec "3:$^0: $^*"
}
.Ed
.Pp
However, the
.Va \&\&on-compose-leave
hook can also used, even though not usable
.Dq as if interactive ,
the
.Ic \&\&digmsg
command, for example, is still accessible.
.Bd -literal -offset indent
\ese on-compose-leave=.sig.embed
\edef .sig.embed {
	readctl creat ~/.mysig
	\eif $? -eq 0
		\elocal readall i
		\eif $? -gt 0
			\eour >message-inject-tail csop trim-end "$i"
		\een
		\ereadctl remo ~/.mysig
	\een
}
.Ed
.Sh "ZZZ THIS AND THAT"
.Bd -literal -offset indent

# Request strict TLS transport layer security checks
\ese tls-verify=strict

# Where are the up-to-date TLS certificates?
# Since we manage up-to-date ones explicitly, do not use any,
# possibly outdated, default certificates shipped with OpenSSL
#\eset tls-ca-dir=/etc/ssl/certs
\eset tls-ca-file=/etc/ssl/certs/ca-certificates.crt \e
	tls-ca-no-defaults
#\eset tls-ca-flags=partial-chain
\eset smime-ca-file=$tls-ca-file smime-ca-no-defaults \e
	smime-ca-flags=$tls-ca-flags

# Could also be outsourced to a central configuration file via
# *tls-config-file* plus *tls-config-module* iff library allows.
# CipherString: explicitly define the list of ciphers, which may
#   improve security, especially with protocols older than TLS v1.2.
#   See ciphers(1).  Possibly best to use *tls-config-pairs-HOST*
#   (or -USER@HOST), as necessary, again..
#   Note that TLSv1.3 uses Ciphersuites= instead, which will join
#   with CipherString (if protocols older than v1.3 are allowed)
# Curves: especially with TLSv1.3 curves selection may be desired.
# MinProtocol,MaxProtocol: do not use protocols older than TLS v1.2.
#   Change this only when the remote server does not support it:
#   maybe use chain support via *tls-config-pairs-HOST* / -USER@HOST
#   to define such explicit exceptions, then, e.g.,
#     MinProtocol=TLSv1.1
\eif $tls-features =% ,+ctx-set-maxmin-proto,
	\eset tls-config-pairs='\e
		CipherString = EECDH+AESGCM:EECDH+AES256:\e
			EDH+AESGCM:CHACHA20:!TLSv1,\e
		Curves=P-521:P-384:P-256,\e
		MinProtocol = TLSv1.2'
\eel
	\eset tls-config-pairs='\e
		CipherString = EECDH+AESGCM:EECDH+AES256:\e
			EDH+AESGCM:CHACHA20:!TLSv1,\e
		Curves = P-521:P-384:P-256,\e
		Protocol = -ALL\e, +TLSv1.2\e, +TLSv1.3'
\een

# Default directory where we act in (relative to $HOME)
\eset folder=mail
# A leading "+" (often) means: under *folder*
# *record* is used to save copies of sent messages
\eset MBOX=+mbox.mbox DEAD=+dead.txt \e
	record=+sent.mbox record-files record-resent

# Make "file mymbox" and "file myrec" go to..
\eshortcut  mymbox %:+mbox.mbox  myrec +sent.mbox

# Not really optional as it is needed for, e.g., S/MIME
\eset from='Your Name <address@exam.ple>'

# It may be necessary to set *hostname* and/or *smtp-from*
# if the "SERVER" of *mta* and "domain" of *from* do not match.
# The `urlencode' command can be used to encode USER and PASS
#\eset mta=(smtps?|submissions?)://[USER[:PASS]@]SERVER[:PORT]
\eset mta=test
\eset \e
	autocollapse autosort=thread \e
	followup-to-add-cc forward-add-cc \e
	history-file=+.mailx-hist history-size=2102102 \e
		history-gabby=all history-gabby-persist \e
	prompt='?\e$?!\e$!/\e$^ERRNAME[\e$account#\e$mailbox-display]? ' \e
	quote=allbodies quote-add-cc \e
	reply-to-swap-in=mlist \e
	sendcharsets=utf-8,iso-8859-1 \e
	umask=

# Only include the selected header fields when printing messages
retain date author sender from to cc subject \e
	message-id mail-followup-to reply-to
#\eheaderpick type retain ...
# - when forwarding messages
#\eheaderpick forward retain date author sender from to cc subject
# - and do not include these when saving message, etc.
#\eif $features =% ,+regex,
#	\eheaderpick save ignore '^Original-.*$' '^X-.*$'
#\eend

# Unify header display
headerorder Author From To Cc Subject Date \e
	Message-ID Reply-To Mail-Followup-To

# Some mailing lists
\emlist  list.one@exam.ple  '@xyz-editor\e.xyz$'  '@xyzf\e.xyz$'
\emlsubscribe  list.two@exam.ple  '^xfans@xfans\e.xyz$'

# A real life example of a very huge free mail provider
# Instead of directly placing content inside `account',
# we `define' a macro: like that we could "switch accounts"
# from within *on-compose-embed*, for example!
\eaccount u1-XooglX {
	\ecall u1-XooglX
}
\edefine u1-XooglX {
	\elocal >a alternates
	\eif -n $a; \eunalternates *; \een
	\ealt u2@XY u3@XY
	\ese \e
		folder=u1-XooglX/mail \e
		hostname=gmail.com \e
		mta=smtp://smtp.gmail.com:587 \e
		nonetrc-lookup \e
		on-account-cleanup=.u1-XooglX-oac \e
		pop3-bulk-load-pop.gmail.com \e
			pop3-no-apop-pop.gmail.com \e
			pop3-keepalive-pop.gmail.com=210 \e
		record=+sent \e
		Sign=$'\en--\enu1' sign=$'\en--U1' \e
			stealthmua=noagent \e
		user=u1
	\ese message-inject-tail=$sign
	\eshortcut  pop %:pop3s://pop.gmail.com \e
		imap %:imaps://imap.gmail.com
	commandalias xp 'fi pop'

	\ese smtp-from=$user@$hostname from='U1 <u1@XmaiX.com>'
	\excall my-oauth-activate u1-XooglX
}
define .u1-XooglX-oac {
	unshortcut pop
	uncommandalias xp
}

# Here is a pretty large one which does not allow sending mails
# if there is a domain name mismatch on the SMTP protocol level,
# which would bite us if the value of *from* does not match, e.g.,
# for people who have a sXXXXeforge project and want to speak
# with the mailing list under their project account (in *from*),
# still sending the message through their normal mail provider
account u1-y {
	\ecall u1-y
}
define u1-y {
	\ese hostname=yandex.com \e
		mta=smtps://smtp.yandex.com:465 \e
		nonetrc-lookup \e
		on-account-cleanup=.u1-y-oac \e
		tls-config-pairs=MinProtocol=TLSv1.3

	\eshortcut imap %:imaps://imap.yandex.com
	ca xi 'fi imap'

	\ese smtp-from=u1@$hostname from='U1 <u1@Y.com>'
	\excall my-oauth-activate u1-y
}
define .u1-y-oac {
	unshortcut imap
	uncommandalias xi
}

# One more
account u1-ms {
	\ecall u1-ms
}
define u1-ms {
	\ese hostname=outlook.com \e
		mta=submission://smtp.office365.com \e
		nonetrc-lookup \e
		on-account-cleanup=.u1-ms-oac \e
		tls-config-pairs=MinProtocol=TLSv1.2 \e
		user=u1@outlook.com
	\eshortcut pop %:pop3s://outlook.office365.com \e
		imap %:imaps://outlook.office365.com
	ca xp 'fi pop'
	ca xi 'fi imap'

	\ese smtp-from=$user from=$user
	\excall my-oauth-activate u1-ms
}
define .u1-oac {
	unshortcut pop imap
	uncommandalias xp xi
}

# Create some new commands so that, e.g., "? ls /tmp" will..
\ecommandalias lls '!ls -aFlrS'
\ecommandalias llS '!ls -aFlS'
