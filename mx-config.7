.Sh "MIME TYPE"
The following example reintegrates HTML formatted by the text browsers
.Xr lynx 1
or
.Xr elinks 1 ,
registers a JSON MIME type handled as plain text,
and establishes a setting to open PDF parts in an external viewer,
asynchronously and with some other magic attached, like
.Sx "Command modifiers" .
.Bd -literal -offset indent
if $features =% ,+filter-html-tagsoup,
	unmimetype text/html
	mimetype ?h text/html html htm
	set cols=72
else
	#set pipe-text/html='?* elinks -force-html -dump 1'
	set pipe-text/html='?* lynx -stdin -dump -force_html'
endif

mimetype ?t application/json json

set pipe-application/pdf='?&=? \e
	trap "rm -f \e"$MAILX_FILENAME_TEMPORARY\e"" EXIT;\e
	trap "trap \e"\e" INT QUIT TERM; exit 1" INT QUIT TERM;\e
	mupdf "$MAILX_FILENAME_TEMPORARY"'
.Ed
.Ss Mailcap
Using mailcap files which are shared in between applications
seems to be a good option; several
.Ql x-mailx-
style options may improve usability.
These files are evaluated top-down.
.Bd -literal -offset indent
if 0 # (do not copy line)
application/pdf;\e
	/Applications/Preview.app/Contents/MacOS/Preview %s;\e
	test = [ "$OSTYPE" = darwin ] >/dev/null 2>&1;\e
	nametemplate=%s.pdf; x-mailx-test-once
application/pdf;\e
	mupdf %s;\e
	test = [ -n "$DISPLAY" ] >/dev/null 2>&1;\e
	nametemplate = %s.pdf; x-mailx-ignore
application/pdf;\e
	infile=%s\e;\e
		trap "rm -f \e"$infile\e"" EXIT\e;\e
		trap "exit 75" INT QUIT TERM\e;\e
		mupdf "$infile";\e
	test = [ -n "$DISPLAY" ] >/dev/null 2>&1;\e
	nametemplate = %s.pdf; x-mailx-async; x-mailx-test-once
application/pdf;\e
	pdfinfo %s\e; pdftotext -layout %s -;\e
	test = command -v pdfinfo >/dev/null 2>&1;\e
	copiousoutput; nametemplate=%s.pdf; x-mailx-test-once

application/*;\e
	echo 'This is "%t", it looks like:'\e;\e
		< %s head -c 512 | cat -vet\e; echo;\e
	copiousoutput; x-mailx-noquote; x-mailx-last-resort

image/*;\e
	display %s;\e
	test = { [ -n "$DISPLAY" ] &&\e
		command -v display\e; } >/dev/null 2>&1;\e
	x-mailx-ignore
image/*;\e
	infile=%s\e;\e
		trap "rm -f \e"$infile\e"" EXIT\e;\e
		trap 'exit 75' INT QUIT TERM\e;\e
		display "$infile";\e
	test = { [ -n "$DISPLAY" ] &&\e
		command -v display\e; } >/dev/null 2>&1;\e
	x-mailx-async; x-mailx-test-once

#text/html; lynx -dump %s; copiousoutput; nametemplate=%s.html
endif # (do not copy line)
